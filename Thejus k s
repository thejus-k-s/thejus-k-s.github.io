<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AstroCET — College of Engineering Trivandrum</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800;900&family=Exo+2:wght@200;300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --neon-cyan: #00f5ff;
  --neon-blue: #0070ff;
  --neon-violet: #a855f7;
  --neon-rose: #f43f5e;
  --bg-void: #020408;
  --bg-deep: #05080f;
  --bg-card: rgba(8, 15, 30, 0.85);
  --bg-card2: rgba(0, 112, 255, 0.04);
  --text-bright: #e8f4ff;
  --text-mid: #7aa8cc;
  --text-dim: #3a5a7a;
  --border-glow: rgba(0, 245, 255, 0.18);
  --border-dim: rgba(0, 112, 255, 0.12);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Exo 2', sans-serif;
  background: var(--bg-void);
  color: var(--text-bright);
  overflow-x: hidden;
  cursor: none;
}

/* CUSTOM CURSOR */
.cursor {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--neon-cyan);
  position: fixed; top: 0; left: 0;
  pointer-events: none; z-index: 9999;
  transform: translate(-50%, -50%);
  transition: transform 0.1s, background 0.2s;
  box-shadow: 0 0 12px var(--neon-cyan), 0 0 24px rgba(0,245,255,0.4);
  mix-blend-mode: screen;
}
.cursor-ring {
  width: 36px; height: 36px;
  border-radius: 50%;
  border: 1px solid rgba(0,245,255,0.4);
  position: fixed; top: 0; left: 0;
  pointer-events: none; z-index: 9998;
  transform: translate(-50%, -50%);
  transition: transform 0.18s ease, width 0.2s, height 0.2s, border-color 0.2s;
}

/* CANVAS */
#cosmos { position: fixed; inset: 0; z-index: 0; pointer-events: none; }

/* SCAN LINE EFFECT */
.scanlines {
  position: fixed; inset: 0; z-index: 1; pointer-events: none;
  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
}

/* GRID OVERLAY */
.grid-bg {
  position: fixed; inset: 0; z-index: 1; pointer-events: none;
  background-image:
    linear-gradient(rgba(0,112,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,112,255,0.04) 1px, transparent 1px);
  background-size: 80px 80px;
  animation: gridPulse 8s ease-in-out infinite;
}
@keyframes gridPulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* NOISE TEXTURE */
body::after {
  content: '';
  position: fixed; inset: 0; z-index: 2; pointer-events: none;
  opacity: 0.025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px 200px;
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 500;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 60px;
  height: 68px;
  background: rgba(2,4,8,0.9);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border-glow);
}
.logo {
  font-family: 'Orbitron', monospace;
  font-size: 20px; font-weight: 900;
  color: var(--neon-cyan);
  letter-spacing: 4px;
  text-shadow: 0 0 20px rgba(0,245,255,0.7), 0 0 40px rgba(0,245,255,0.3);
  text-decoration: none;
  display: flex; align-items: center; gap: 10px;
}
.logo-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--neon-cyan);
  box-shadow: 0 0 12px var(--neon-cyan);
  animation: blink 2s ease-in-out infinite;
}
@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.2;} }

.nav-links { display: flex; gap: 36px; list-style: none; }
.nav-links a {
  font-size: 12px; font-weight: 500; letter-spacing: 2.5px;
  color: var(--text-mid); text-decoration: none; text-transform: uppercase;
  transition: color 0.3s, text-shadow 0.3s;
  position: relative;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -4px; left: 0; right: 0;
  height: 1px; background: var(--neon-cyan);
  transform: scaleX(0); transform-origin: left;
  transition: transform 0.3s;
}
.nav-links a:hover { color: var(--neon-cyan); text-shadow: 0 0 10px rgba(0,245,255,0.5); }
.nav-links a:hover::after { transform: scaleX(1); }

.nav-join {
  font-family: 'Orbitron', monospace; font-size: 10px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase; text-decoration: none;
  color: var(--bg-void); background: var(--neon-cyan);
  padding: 10px 24px;
  clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
  transition: all 0.3s;
  box-shadow: 0 0 20px rgba(0,245,255,0.3);
}
.nav-join:hover {
  background: #fff;
  box-shadow: 0 0 32px rgba(0,245,255,0.7);
  transform: translateY(-1px);
}

/* HERO */
#hero {
  position: relative; z-index: 10;
  min-height: 100vh;
  display: flex; flex-direction: column;
  justify-content: center;
  padding: 140px 80px 100px;
  overflow: hidden;
}

.hero-eyebrow {
  font-family: 'Orbitron', monospace;
  font-size: 11px; letter-spacing: 5px; text-transform: uppercase;
  color: var(--neon-violet);
  display: flex; align-items: center; gap: 14px;
  margin-bottom: 28px;
  animation: fadeUp 0.8s ease 0.2s both;
}
.hero-eyebrow::before {
  content: ''; width: 50px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--neon-violet));
}
.hero-eyebrow::after {
  content: ''; width: 50px; height: 1px;
  background: linear-gradient(90deg, var(--neon-violet), transparent);
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}

.hero-title {
  font-family: 'Orbitron', monospace;
  font-size: clamp(52px, 8.5vw, 110px);
  font-weight: 900;
  line-height: 0.95;
  color: #fff;
  margin-bottom: 8px;
  animation: fadeUp 0.8s ease 0.4s both;
}
.hero-title .outline {
  color: transparent;
  -webkit-text-stroke: 2px var(--neon-cyan);
  filter: drop-shadow(0 0 20px rgba(0,245,255,0.5));
}
.hero-title .glow {
  text-shadow: 0 0 40px rgba(0,245,255,0.4);
  color: var(--neon-cyan);
}

.hero-tagline {
  font-size: 20px; font-weight: 200; letter-spacing: 0.5px;
  color: var(--text-mid); line-height: 1.8;
  max-width: 600px; margin-bottom: 52px;
  animation: fadeUp 0.8s ease 0.6s both;
}
.hero-tagline strong { color: var(--neon-cyan); font-weight: 500; }

.hero-ctas {
  display: flex; gap: 16px; flex-wrap: wrap;
  animation: fadeUp 0.8s ease 0.8s both;
}

.cta-primary {
  font-family: 'Orbitron', monospace; font-size: 11px; font-weight: 700;
  letter-spacing: 2.5px; text-transform: uppercase; text-decoration: none;
  color: var(--bg-void); background: var(--neon-cyan);
  padding: 16px 36px;
  clip-path: polygon(14px 0%, 100% 0%, calc(100% - 14px) 100%, 0% 100%);
  box-shadow: 0 0 30px rgba(0,245,255,0.4), 0 0 60px rgba(0,245,255,0.15);
  transition: all 0.3s; display: inline-block;
}
.cta-primary:hover {
  background: #fff; transform: translateY(-3px);
  box-shadow: 0 0 40px rgba(0,245,255,0.8), 0 8px 30px rgba(0,0,0,0.5);
}

.cta-secondary {
  font-family: 'Orbitron', monospace; font-size: 11px; font-weight: 600;
  letter-spacing: 2.5px; text-transform: uppercase; text-decoration: none;
  color: var(--neon-cyan); border: 1px solid var(--border-glow);
  padding: 16px 36px;
  clip-path: polygon(14px 0%, 100% 0%, calc(100% - 14px) 100%, 0% 100%);
  transition: all 0.3s; display: inline-block;
  background: transparent;
}
.cta-secondary:hover {
  border-color: var(--neon-cyan);
  background: rgba(0,245,255,0.05);
  box-shadow: 0 0 20px rgba(0,245,255,0.2);
}

/* HERO METRICS */
.hero-metrics {
  display: flex; gap: 0; margin-top: 80px;
  border-top: 1px solid var(--border-dim);
  animation: fadeUp 0.8s ease 1s both;
}
.metric {
  flex: 1; padding: 28px 0; border-right: 1px solid var(--border-dim);
  display: flex; flex-direction: column; gap: 6px;
}
.metric:last-child { border-right: none; }
.metric-num {
  font-family: 'Orbitron', monospace; font-size: 36px; font-weight: 800;
  color: var(--neon-cyan);
  text-shadow: 0 0 20px rgba(0,245,255,0.5);
}
.metric-label { font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-dim); }

/* HERO PLANET */
.hero-planet {
  position: absolute; right: -60px; top: 50%; transform: translateY(-50%);
  width: 550px; height: 550px; pointer-events: none;
  animation: rotatePlanet 40s linear infinite;
}
@keyframes rotatePlanet { from{transform:translateY(-50%) rotate(0deg);} to{transform:translateY(-50%) rotate(360deg);} }

/* FLOATING BADGE */
.live-badge {
  position: absolute; top: 180px; right: 280px;
  display: flex; align-items: center; gap: 10px;
  background: rgba(8,15,30,0.9); border: 1px solid rgba(0,245,255,0.3);
  padding: 12px 20px;
  animation: floatBadge 4s ease-in-out infinite, fadeUp 0.8s ease 1.2s both;
  clip-path: polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);
}
@keyframes floatBadge { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-8px);} }
.live-dot { width:8px;height:8px;border-radius:50%;background:#f43f5e; animation:blink 1.2s ease-in-out infinite; }
.live-text { font-family:'Orbitron',monospace; font-size:10px; letter-spacing:2px; color:var(--text-mid); }
.live-text span { color:#f43f5e; }

/* SCROLL INDICATOR */
.scroll-hint {
  position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  animation: fadeUp 0.8s ease 1.4s both;
}
.scroll-line {
  width: 1px; height: 60px;
  background: linear-gradient(180deg, var(--neon-cyan), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}
@keyframes scrollPulse { 0%,100%{opacity:0.3;transform:scaleY(1);} 50%{opacity:1;transform:scaleY(1.2);} }
.scroll-label { font-size:10px;letter-spacing:3px;color:var(--text-dim);text-transform:uppercase; }

/* SECTION SHARED */
section { position: relative; z-index: 10; }

.sec-wrap { padding: 100px 80px; }

.sec-header { margin-bottom: 64px; }
.sec-tag {
  font-family: 'Orbitron', monospace; font-size: 10px; letter-spacing: 4px;
  text-transform: uppercase; color: var(--neon-cyan);
  display: flex; align-items: center; gap: 14px; margin-bottom: 18px;
}
.sec-tag::after {
  content: ''; height: 1px; width: 80px;
  background: linear-gradient(90deg, var(--neon-cyan), transparent);
}
.sec-title {
  font-family: 'Orbitron', monospace;
  font-size: clamp(30px, 4vw, 50px); font-weight: 800;
  color: #fff; line-height: 1.1;
}
.sec-title span { color: var(--neon-cyan); }
.sec-sub { font-size: 17px; font-weight: 300; color: var(--text-mid); margin-top: 14px; line-height: 1.8; max-width: 560px; }

/* ABOUT */
#about { background: linear-gradient(180deg, var(--bg-void) 0%, #030610 100%); }
.about-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 80px; align-items: center; }

.about-body { font-size: 16px; line-height: 1.95; color: var(--text-mid); }
.about-body p { margin-bottom: 20px; }
.about-body strong { color: var(--neon-cyan); font-weight: 500; }

.pillars { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 36px; }
.pillar {
  border: 1px solid var(--border-glow); background: var(--bg-card);
  padding: 22px;
  position: relative; overflow: hidden;
  clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 14px 100%, 0 calc(100% - 14px));
  transition: border-color 0.3s, transform 0.3s;
}
.pillar::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0;
  height: 2px; background: linear-gradient(90deg, var(--neon-cyan), transparent);
  transform: scaleX(0); transform-origin: left; transition: transform 0.4s;
}
.pillar:hover { border-color: rgba(0,245,255,0.4); transform: translateY(-4px); }
.pillar:hover::before { transform: scaleX(1); }
.pillar-icon { font-size: 24px; margin-bottom: 12px; display: block; }
.pillar-name { font-family:'Orbitron',monospace; font-size:12px;font-weight:600;letter-spacing:1.5px;color:#fff;margin-bottom:6px; }
.pillar-desc { font-size:13px;color:var(--text-dim);line-height:1.6; }

/* TERMINAL STYLE BOX */
.terminal {
  background: #030a14; border: 1px solid var(--border-glow);
  padding: 28px 32px;
  font-family: 'Courier New', monospace;
  position: relative;
  clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));
}
.terminal-header {
  display: flex; align-items: center; gap: 8px; margin-bottom: 20px;
  padding-bottom: 16px; border-bottom: 1px solid var(--border-dim);
}
.t-dot { width:10px;height:10px;border-radius:50%; }
.t-dot.r{background:#f43f5e;} .t-dot.y{background:#fbbf24;} .t-dot.g{background:#22c55e;}
.terminal-title { font-size:11px;letter-spacing:2px;color:var(--text-dim);margin-left:6px; }
.t-line { font-size: 14px; color: var(--neon-cyan); line-height: 2.2; }
.t-line .t-prompt { color: var(--neon-violet); }
.t-line .t-cmd { color: #fff; }
.t-line .t-output { color: var(--text-mid); }
.t-cursor { display:inline-block;width:8px;height:16px;background:var(--neon-cyan);animation:blink 1s step-end infinite;vertical-align:middle; }

/* EVENTS */
#events { background: linear-gradient(180deg, #030610 0%, #040812 100%); }
.events-list { display: flex; flex-direction: column; gap: 18px; }

.event-card {
  background: var(--bg-card); border: 1px solid var(--border-dim);
  display: grid; grid-template-columns: 90px 1fr auto;
  gap: 28px; align-items: center; padding: 28px 32px;
  transition: border-color 0.3s, background 0.3s, transform 0.3s;
  position: relative; overflow: hidden;
  clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%);
}
.event-card::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(90deg, rgba(0,245,255,0.03) 0%, transparent 100%);
  opacity: 0; transition: opacity 0.3s;
}
.event-card:hover { border-color: var(--border-glow); transform: translateX(6px); }
.event-card:hover::before { opacity: 1; }
.event-card.featured { border-color: rgba(0,245,255,0.35); }
.event-card.featured .ev-date-box { background: var(--neon-cyan); color: var(--bg-void); }

.ev-date-box {
  background: rgba(0,245,255,0.08); border: 1px solid var(--border-glow);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 72px; gap: 2px;
}
.ev-month { font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:600; }
.ev-day { font-family:'Orbitron',monospace;font-size:26px;font-weight:800;line-height:1; }

.ev-title { font-family:'Orbitron',monospace;font-size:15px;font-weight:700;color:#fff;margin-bottom:6px; }
.ev-meta { font-size:13px;color:var(--text-dim);letter-spacing:0.5px; }
.ev-meta span { color:var(--text-mid); }

.ev-badge {
  font-family:'Orbitron',monospace; font-size:9px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase; padding:7px 16px;
  clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);
  white-space:nowrap;
}
.badge-live { background:rgba(244,63,94,0.15);color:#f43f5e;border:1px solid rgba(244,63,94,0.3); }
.badge-soon { background:rgba(0,245,255,0.08);color:var(--neon-cyan);border:1px solid var(--border-glow); }
.badge-open { background:rgba(168,85,247,0.1);color:var(--neon-violet);border:1px solid rgba(168,85,247,0.3); }
.badge-done { background:rgba(58,90,122,0.2);color:var(--text-dim);border:1px solid var(--border-dim); }

/* HIGHLIGHTS */
.highlight-strip {
  background: linear-gradient(90deg, transparent, rgba(0,245,255,0.05), transparent);
  border-top: 1px solid var(--border-glow); border-bottom: 1px solid var(--border-glow);
  padding: 18px 80px; margin-top: 60px;
  display: flex; gap: 60px; overflow: hidden;
  position: relative;
}
.hl-item { font-family:'Orbitron',monospace;font-size:11px;letter-spacing:2px;color:var(--text-mid);white-space:nowrap; }
.hl-item::before { content:'✦  ';color:var(--neon-cyan); }

/* FEATURE SKY — Astronomical Objects */
#sky { background: #040812; }
.sky-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

.sky-card {
  background: var(--bg-card); border: 1px solid var(--border-dim);
  padding: 36px 28px;
  position: relative; overflow: hidden;
  transition: border-color 0.4s, transform 0.4s;
  clip-path: polygon(0 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%);
}
.sky-card:hover { border-color: var(--border-glow); transform: translateY(-6px); }
.sky-card::after {
  content:'';position:absolute;bottom:0;right:0;
  width:100px;height:100px;
  background:radial-gradient(circle at bottom right, rgba(0,245,255,0.06), transparent 70%);
}

.sky-icon { font-size:44px;margin-bottom:20px;display:block;line-height:1; }
.sky-name { font-family:'Orbitron',monospace;font-size:16px;font-weight:700;color:#fff;margin-bottom:10px; }
.sky-desc { font-size:14px;color:var(--text-mid);line-height:1.8;margin-bottom:20px; }
.sky-tag {
  display:inline-block;font-size:10px;letter-spacing:2px;text-transform:uppercase;
  color:var(--neon-cyan);border:1px solid var(--border-glow);
  padding:4px 12px;
}

/* TEAM */
#team { background: linear-gradient(180deg, #040812 0%, var(--bg-void) 100%); }
.team-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }

.member-card {
  background: var(--bg-card); border: 1px solid var(--border-dim);
  padding: 32px 22px; text-align: center;
  position: relative; overflow: hidden;
  transition: border-color 0.3s, transform 0.3s;
  clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 0 100%);
}
.member-card:hover { border-color: var(--border-glow); transform: translateY(-5px); }
.member-card:hover .member-avatar { box-shadow: 0 0 30px rgba(0,245,255,0.4); }

.member-avatar {
  width: 80px; height: 80px; border-radius: 50%;
  background: linear-gradient(135deg, rgba(0,112,255,0.3), rgba(168,85,247,0.3));
  border: 2px solid var(--border-glow);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 18px; font-family:'Orbitron',monospace;
  font-size:20px; font-weight:800; color:var(--neon-cyan);
  transition: box-shadow 0.3s;
}
.member-name { font-family:'Orbitron',monospace;font-size:13px;font-weight:700;color:#fff;margin-bottom:6px; }
.member-role {
  font-size:11px;letter-spacing:2px;text-transform:uppercase;
  color:var(--neon-cyan);margin-bottom:8px;
}
.member-dept { font-size:12px;color:var(--text-dim); }
.member-socials { display:flex;justify-content:center;gap:10px;margin-top:16px; }
.social-link {
  width:30px;height:30px;border:1px solid var(--border-dim);
  display:flex;align-items:center;justify-content:center;
  color:var(--text-dim);font-size:13px;text-decoration:none;
  transition:all 0.3s;
}
.social-link:hover { border-color:var(--neon-cyan);color:var(--neon-cyan); }

/* GALLERY */
#gallery { background: var(--bg-void); }
.gallery-mosaic {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: 180px 180px;
  gap: 12px;
}
.gallery-mosaic .g-item { position:relative;overflow:hidden;background:rgba(8,15,30,0.9); }
.gallery-mosaic .g-item:nth-child(1) { grid-column: span 2; grid-row: span 2; }
.gallery-mosaic .g-item:nth-child(4) { grid-column: span 2; }

.g-img {
  width:100%; height:100%;
  display:flex;align-items:center;justify-content:center;
  font-size:60px; position:relative;
  transition: transform 0.5s;
}
.g-item:hover .g-img { transform: scale(1.08); }
.g-overlay {
  position:absolute;inset:0;
  background:linear-gradient(135deg, rgba(0,112,255,0.15), rgba(168,85,247,0.1));
  border:1px solid var(--border-dim);
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:16px;
  opacity:0;transition:opacity 0.3s;
}
.g-item:hover .g-overlay { opacity:1; }
